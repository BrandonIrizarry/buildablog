<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/static/styles.css">
        <title>Projects</title>
    </head>
    <body>
        {{ template "nav.html" . }}
        <main class="project-gallery">
            {{ range . }}
                {{ with .Frontmatter }}
                    <section class="project-entry">
                        <h2 class="meta">{{ .Name }}</h2>
                        <ul>
                            {{ range .Stack }}
                                <li>{{ . }}</li>
                            {{ end }}
                        </ul>
                        <p>{{ .Synopsis }}</p>
                    </section>
                {{ end }}
            {{ end }}
        </main>
    </body>
</html>
