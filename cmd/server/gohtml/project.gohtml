{{ define "project" }}

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/static/styles.css">
        <title>{{ .Frontmatter.Name }}</title>
    </head>
    <body>
         {{ template "nav" . }}
        <main class="post-content">
           {{ .Frontmatter.Content }}
        </main>
    </body>
</html>

{{ end }}
